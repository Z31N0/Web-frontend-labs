{
  "extends": "stylelint-config-standard",
  "plugins": [
    "stylelint-scss"
  ],
  "rules": {
    "declaration-no-important": true,
    "property-disallowed-list": ["position", "grid", "float"],
    "unit-disallowed-list": ["px","pt","cm","mm","in","pc"],
    "selector-disallowed-list": ["*"],
"no-descending-specificity": null,
  "value-keyword-case": [
    "lower",
    {
    "ignoreProperties": ["/^!--/"]
    }
    ]
  }
}
